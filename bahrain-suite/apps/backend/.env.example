# --- Bahrain Properties API (.env) — copy to .env and fill in ---
# See docs/RUNBOOK.md for full checklist.

# API listen port (Next.js dev uses 3001; keep API on 3000 by default)
PORT=3000

# PostgreSQL (TypeORM: synchronize=false — apply schema via SQL/migrations)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=bahrain_properties

# Optional: Docker Postgres that matches a dedicated app user (see docker-compose.postgres.yml).
# After `npm run db:up`, use e.g. DB_HOST=127.0.0.1 DB_PORT=5433 DB_USERNAME=bahrain_app DB_PASSWORD=Postgres

# Browser origins allowed (comma-separated). Must include your Next dev URL.
# If unset, localhost:3001 and 127.0.0.1:3001 are allowed by default.
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001

# JWT — use a long random value in production (e.g. openssl rand -hex 48)
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# Public POST /api/v1/auth/register (staff role only). Set to 0, false, no, or off to disable.
# Pair with frontend NEXT_PUBLIC_ENABLE_SELF_SIGNUP=0 in production.
# ALLOW_PUBLIC_REGISTER=0

# E2E: npm run test:e2e requires these DB settings to succeed (AppModule connects at startup).
#
# Optional local admin: after create-users-table.sql, run
# src/database/migrations/008_seed_dev_user.sql — then sign in as dev@example.com / AxtellaDev2024!
# (documented in docs/RUNBOOK.md).
