{
  "name": "bahrain-properties-backend",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "verify:public": "bash scripts/verify-public-endpoints.sh",
    "db:backup": "bash scripts/db-backup.sh",
    "db:check": "bash scripts/db-check-connection.sh",
    "db:up": "docker compose -f docker-compose.postgres.yml up -d --wait",
    "db:down": "docker compose -f docker-compose.postgres.yml down",
    "db:reset": "docker compose -f docker-compose.postgres.yml down -v && docker compose -f docker-compose.postgres.yml up -d --wait",
    "scaffold:zip": "python3 scripts/generate_scaffold_zip.py",
    "db:seed-dev-user": "bash scripts/db-seed-dev-user.sh",
    "db:migrate": "bash scripts/db-apply-migrations.sh",
    "db:migrate:platform": "bash scripts/db-apply-platform-migrations.sh",
    "db:migrate:hotel": "bash scripts/db-apply-hotel-migrations.sh",
    "test:e2e": "jest --config ./jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
