# --- Bahrain Properties frontend — copy to .env.local ---
# Public vars only (exposed to the browser). See docs/RUNBOOK.md.

# Recommended local dev: leave NEXT_PUBLIC_API_BASE_URL unset.
# The app then calls same-origin /api/v1 and Next.js proxies to Nest (see next.config.mjs).
# That fixes login when you use http://127.0.0.1:3001 or a LAN IP instead of "localhost".
#
# For split hosting (UI and API on different domains), set the full API base, e.g.:
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1

# Where Nest serves /docs (used for Developer page links). Default 127.0.0.1:3000.
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:3000

# Optional: white-label module for top bar tile + module-branded pages (fms | avl | iots | eagleEye).
# NEXT_PUBLIC_BRAND_MODULE=fms

# Dev credentials strip on /login: shown automatically in `next dev` (after db:seed-dev-user). To hide: NEXT_PUBLIC_HIDE_DEV_LOGIN_HINT=1
# Production (`next build` / `next start`): off unless you set NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=1 (avoid in real prod).
# NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=1
# NEXT_PUBLIC_HIDE_DEV_LOGIN_HINT=1

# Public self-signup UI on /login (“Create account”). Set to 0 or false to hide (recommended for production).
# Must match backend ALLOW_PUBLIC_REGISTER when you disable API signup.
# NEXT_PUBLIC_ENABLE_SELF_SIGNUP=0

# Optional: if Nest is not on 127.0.0.1:3000, set for the dev proxy only (not exposed to the browser).
# API_PROXY_TARGET=http://127.0.0.1:3000

# E2E (Playwright): with Nest + Next running, from apps/frontend run: npm run test:e2e
# First time: npm run test:e2e:install
# E2E_BASE_URL=http://127.0.0.1:3001
