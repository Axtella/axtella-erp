# ---------------------------------------------------------------------
# Axtella ERP Suit Root Environment Map
# Copy values into each service-specific env file as shown below.
# ---------------------------------------------------------------------

# Shared local ports
BAHRAIN_BACKEND_PORT=3000
BAHRAIN_FRONTEND_PORT=3001
AXTELLA_BACKEND_PORT=3010

# Frontend -> Bahrain backend proxy target (server-side in Next.js)
API_PROXY_TARGET=http://127.0.0.1:3000

# ============================================================================
# Service env ownership map (edit service files, not this root file)
# ============================================================================

# Bahrain backend file:
#   bahrain-suite/apps/backend/.env
# Required keys:
#   PORT=${BAHRAIN_BACKEND_PORT}
#   DB_HOST=
#   DB_PORT=
#   DB_USER=
#   DB_PASS=
#   DB_NAME=
#   CORS_ORIGIN=http://localhost:${BAHRAIN_FRONTEND_PORT}
#   JWT_SECRET=
#   JWT_EXPIRES_IN=

# Bahrain frontend file:
#   bahrain-suite/apps/frontend/.env.local
# Required keys:
#   API_PROXY_TARGET=${API_PROXY_TARGET}
#   NEXT_PUBLIC_API_ORIGIN=http://localhost:${BAHRAIN_BACKEND_PORT}
# Optional split-host key:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:${BAHRAIN_BACKEND_PORT}/api/v1

# Bahrain mobile file:
#   bahrain-suite/apps/mobile/.env
# Required key:
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:${BAHRAIN_BACKEND_PORT}/api/v1

# Axtella backend file:
#   axtella-backend-zatca/.env
# Required keys:
#   PORT=${AXTELLA_BACKEND_PORT}
#   DB_HOST=
#   DB_PORT=
#   DB_USERNAME=
#   DB_PASSWORD=
#   DB_NAME=
#   CORS_ORIGIN=http://localhost:${BAHRAIN_FRONTEND_PORT}
#   ZATCA_ENVIRONMENT=sandbox
#   ZATCA_BASE_URL=
#   ZATCA_CSID=
#   ZATCA_BINARY_SECURITY_TOKEN=
#   ZATCA_SECRET=
